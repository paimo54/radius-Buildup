# ========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ========================================
# Copy this file to .env for production setup
# CRITICAL: Change all default values before deploying!

# ========================================
# DATABASE - MySQL/MariaDB
# ========================================
DATABASE_URL="mysql://username:password@localhost:3306/salfanet_radius?connection_limit=10&pool_timeout=20"

# ========================================
# TIMEZONE - CRITICAL for WIB handling
# ========================================
TZ="Asia/Jakarta"
NEXT_PUBLIC_TIMEZONE="Asia/Jakarta"

# ========================================
# APPLICATION CONFIGURATION
# ========================================
NEXT_PUBLIC_APP_NAME="Your ISP Name"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NODE_ENV="production"

# ========================================
# NEXTAUTH - CRITICAL SECURITY
# ========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_THIS_TO_RANDOM_STRING_32_CHARS_MIN"
NEXTAUTH_URL="https://yourdomain.com"

# ========================================
# RADIUS SERVER CONFIGURATION
# ========================================
# Public IP for MikroTik scripts
RADIUS_SERVER_IP="YOUR_VPS_PUBLIC_IP"
VPS_IP="YOUR_VPS_PUBLIC_IP"

# ========================================
# PAYMENT GATEWAY - MIDTRANS
# ========================================
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_IS_PRODUCTION="true"

# ========================================
# PAYMENT GATEWAY - XENDIT (Optional)
# ========================================
# XENDIT_SECRET_KEY="your-xendit-secret-key"
# XENDIT_WEBHOOK_TOKEN="your-xendit-webhook-token"

# ========================================
# EMAIL CONFIGURATION - Gmail SMTP
# ========================================
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-specific-password"
EMAIL_FROM="Your ISP Name <your-email@gmail.com>"

# ========================================
# WHATSAPP INTEGRATION (Optional)
# ========================================
# WHATSAPP_API_URL="https://your-whatsapp-gateway.com/api"
# WHATSAPP_API_KEY="your-api-key"

# ========================================
# SECURITY & PERFORMANCE
# ========================================
# Rate limiting
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="15"

# Session
SESSION_MAX_AGE="86400"

# ========================================
# WEB PUSH / PWA
# ========================================
# Generate with: npm run push:vapid
VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="YOUR_VAPID_PRIVATE_KEY"
VAPID_CONTACT_EMAIL="admin@yourdomain.com"

# ========================================
# LOGGING & MONITORING
# ========================================
LOG_LEVEL="error"
ENABLE_QUERY_LOGGING="false"
