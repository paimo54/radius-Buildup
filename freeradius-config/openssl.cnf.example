# OpenSSL Configuration for FreeRADIUS MS-CHAP Support
# =====================================================
#
# This is an example openssl.cnf file with LEGACY PROVIDER ENABLED.
# This is REQUIRED for FreeRADIUS MS-CHAP authentication on OpenSSL 3.0+
#
# LOCATION: /etc/ssl/openssl.cnf (Ubuntu 22.04)
#
# The key changes from default are in [openssl_init], [provider_sect], 
# [legacy_sect], and [default_sect] sections.
#
# To verify MD4 is working after configuration:
#   echo -n 'test' | openssl dgst -md4
#
# If you see a hash output instead of "unknown option", MD4 is enabled.
#

# ===== KEY SECTIONS TO MODIFY =====

# Section 1: Ensure openssl_conf points to openssl_init
#
# Near the top of the file, ensure this line exists:
# openssl_conf = openssl_init

# Section 2: Define openssl_init to load providers
#
# [openssl_init]
# providers = provider_sect
# ssl_conf = ssl_sect

# Section 3: Enable legacy and default providers
#
# [provider_sect]
# legacy = legacy_sect
# default = default_sect

# Section 4: Activate legacy provider (THIS IS THE KEY FIX!)
#
# [legacy_sect]
# activate = 1

# Section 5: Activate default provider
#
# [default_sect]
# activate = 1

# ===== FULL WORKING EXAMPLE SECTIONS =====

# Add/modify these sections in your /etc/ssl/openssl.cnf:

#--------------------------------------------------------------
# openssl_conf = openssl_init  # At the top of the file
#
# [openssl_init]
# providers = provider_sect
# ssl_conf = ssl_sect
#
# [provider_sect]
# legacy = legacy_sect
# default = default_sect
#
# [legacy_sect]
# activate = 1
#
# [default_sect]
# activate = 1
#--------------------------------------------------------------

